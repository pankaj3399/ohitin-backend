# ============================================
# Environment Variables Example (Dummy Values)
# ============================================

# JWT Secret (use a long random string in real env)
JWT_SECRET=your-jwt-secret-here

# MongoDB Connection URL
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database-name


# API Keys (keep real keys in .env only)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Instagram DM Integration
# Access token and webhook verify token are managed in the DB (MetaSettings),
# configured via the admin Settings page — not through env vars.
# Secret protecting the scheduled token-refresh endpoint. Vercel cron sends this
# automatically as `Authorization: Bearer <CRON_SECRET>`. Use a long random string.
CRON_SECRET=your-long-random-cron-secret